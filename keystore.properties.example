# Copier ce fichier vers keystore.properties à la RACINE du projet (à côté de settings.gradle.kts).
# keystore.properties est ignoré par Git — ne jamais le committer.
#
# 1) Créer un keystore de dépôt (une fois), depuis la racine du projet :
#
#    keytool -genkey -v -keystore ogoula-upload.jks -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
#    Répondre aux questions ; noter les mots de passe.
#
# 2) Remplir keystore.properties :

storeFile=ogoula-upload.jks
storePassword=TON_MOT_DE_PASSE_KEYSTORE
keyAlias=upload
keyPassword=TON_MOT_DE_PASSE_CLE

# storeFile est relatif à la racine du dépôt (dossier ogoula). Tu peux mettre un chemin absolu si besoin.
